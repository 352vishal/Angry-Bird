/* ==========================
   FIREWORK EFFECT
========================== */

function createFirework(){

    const firework=document.createElement("div");

    firework.style.position="fixed";
    firework.style.left=Math.random()*100+"vw";
    firework.style.top=(20+Math.random()*50)+"vh";
    firework.style.width="8px";
    firework.style.height="8px";
    firework.style.borderRadius="50%";
    firework.style.background="#fff";
    firework.style.zIndex="99999";

    document.body.appendChild(firework);

    const colors=[
        "#ff4d95",
        "#FFD93D",
        "#6BCBFF",
        "#9D4EDD",
        "#00F5D4",
        "#ffffff"
    ];

    for(let i=0;i<24;i++){

        const particle=document.createElement("div");

        particle.style.position="fixed";
        particle.style.left=firework.style.left;
        particle.style.top=firework.style.top;
        particle.style.width="6px";
        particle.style.height="6px";
        particle.style.borderRadius="50%";
        particle.style.background=
        colors[Math.floor(Math.random()*colors.length)];

        particle.style.zIndex="99999";

        document.body.appendChild(particle);

        const angle=(360/24)*i;

        const distance=70+Math.random()*60;

        particle.animate([

            {
                transform:"translate(0,0) scale(1)",
                opacity:1
            },

            {
                transform:
                `translate(
                ${Math.cos(angle*Math.PI/180)*distance}px,
                ${Math.sin(angle*Math.PI/180)*distance}px)
                scale(0)`,

                opacity:0
            }

        ],{

            duration:900,

            easing:"ease-out"

        });

        setTimeout(()=>{

            particle.remove();

        },900);

    }

    firework.remove();

}


