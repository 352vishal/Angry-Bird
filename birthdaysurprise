<style>

/* ==========================================
   GOOGLE FONT
========================================== */

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Parisienne&display=swap');

/* ==========================================
   RESET
========================================== */

*{
margin:0;
padding:0;
box-sizing:border-box;
-webkit-tap-highlight-color:transparent;
}

html{
scroll-behavior:smooth;
}

body{

font-family:'Poppins',sans-serif;

overflow:hidden;

background:#111;

color:#fff;

}

/* ==========================================
BACKGROUND
========================================== */

.background{

position:fixed;

left:0;
top:0;

width:100%;
height:100%;

z-index:-5;

background:linear-gradient(
135deg,
#ff9ac8,
#ffc8dd,
#cdb4ff,
#bde0fe,
#fff1b6
);

background-size:500% 500%;

animation:bgMove 15s ease infinite;

}

@keyframes bgMove{

0%{
background-position:0% 50%;
}

50%{
background-position:100% 50%;
}

100%{
background-position:0% 50%;
}

}

/* ==========================================
BLUR BLOBS
========================================== */

.blur{

position:fixed;

border-radius:50%;

filter:blur(100px);

opacity:.35;

z-index:-4;

animation:blobMove 12s ease-in-out infinite;

}

.blob1{

width:240px;
height:240px;

background:#ff6db3;

top:-60px;
left:-40px;

}

.blob2{

width:260px;
height:260px;

background:#8a6cff;

right:-80px;
top:180px;

animation-delay:3s;

}

.blob3{

width:220px;
height:220px;

background:#71d8ff;

bottom:30px;
left:20px;

animation-delay:6s;

}

.blob4{

width:260px;
height:260px;

background:#ffd46d;

bottom:-80px;
right:20px;

animation-delay:9s;

}

@keyframes blobMove{

0%,100%{

transform:translate(0,0);

}

50%{

transform:translate(40px,-40px);

}

}

/* ==========================================
APP
========================================== */

.app{

width:100%;

height:100vh;

display:flex;

justify-content:center;

align-items:center;

padding:20px;

}

/* ==========================================
GLASS
========================================== */

.glass{

background:rgba(255,255,255,.18);

border:1px solid rgba(255,255,255,.28);

backdrop-filter:blur(18px);

-webkit-backdrop-filter:blur(18px);

box-shadow:0 20px 40px rgba(0,0,0,.18);

border-radius:30px;

}

/* ==========================================
NAVBAR
========================================== */

.navbar{

position:fixed;

top:20px;

left:50%;

transform:translateX(-50%);

width:92%;

max-width:430px;

height:72px;

display:flex;

justify-content:space-between;

align-items:center;

padding:0 18px;

z-index:999;

}

.logo{

font-size:20px;

font-weight:700;

}

.nav-links{

display:flex;

gap:12px;

}

.nav-btn{

width:45px;

height:45px;

border:none;

border-radius:50%;

cursor:pointer;

font-size:20px;

background:rgba(255,255,255,.18);

color:white;

transition:.35s;

}

.nav-btn:hover{

transform:translateY(-4px);

}

.nav-btn.active{

background:white;

color:#ff4fa0;

}

#musicButton{

width:45px;

height:45px;

border:none;

border-radius:50%;

cursor:pointer;

background:white;

font-size:20px;

transition:.35s;

}

#musicButton:hover{

transform:rotate(20deg);

}

/* ==========================================
PAGES
========================================== */

.page{

display:none;

width:100%;

height:100vh;

justify-content:center;

align-items:center;

animation:fade .4s;

}

.page.active{

display:flex;

}

@keyframes fade{

from{

opacity:0;

transform:translateY(20px);

}

to{

opacity:1;

transform:none;

}

}

/* ==========================================
HERO
========================================== */

.hero-card{

max-width:430px;

padding:35px;

text-align:center;

}

.tag{

display:block;

font-size:12px;

letter-spacing:3px;

margin-bottom:15px;

opacity:.8;

}

.hero-card h1{

font-size:42px;

font-family:'Parisienne',cursive;

margin-bottom:10px;

}

.hero-card h2{

font-size:34px;

margin-bottom:20px;

}

.hero-card p{

line-height:1.9;

opacity:.95;

margin-bottom:35px;

}

#startSurprise{

width:100%;

height:60px;

border:none;

border-radius:18px;

background:white;

color:#ff4da0;

font-size:18px;

font-weight:600;

cursor:pointer;

transition:.35s;

}

#startSurprise:hover{

transform:translateY(-5px);

box-shadow:0 15px 30px rgba(255,255,255,.3);

}

/* ==========================================
   BALLOON PAGE
========================================== */

.balloon-card{

    width:100%;
    max-width:430px;

    padding:35px;

    text-align:center;

}

.balloon-card h2{

    font-size:30px;

    margin-bottom:10px;

}

.balloon-text{

    opacity:.9;

    line-height:1.7;

    margin-bottom:20px;

}

#counter{

    margin:20px 0;

    font-size:18px;

    font-weight:600;

    color:#fff;

}

/* ==========================================
   BALLOON CONTAINER
========================================== */

.balloon-container{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:35px;

    justify-items:center;

    margin-top:25px;

}

.balloon-container .balloon:last-child{

    grid-column:1 / span 2;

}

/* ==========================================
   BALLOON
========================================== */

.balloon{

    width:90px;

    height:115px;

    border-radius:50% 50% 45% 45%;

    cursor:pointer;

    position:relative;

    transition:.35s;

    animation:float 4s ease-in-out infinite;

    box-shadow:

    inset -10px -15px 20px rgba(0,0,0,.12),

    0 18px 30px rgba(0,0,0,.25);

}

.balloon:hover{

    transform:translateY(-10px) scale(1.08);

}

.balloon::before{

    content:"";

    position:absolute;

    width:14px;

    height:14px;

    bottom:-8px;

    left:50%;

    transform:translateX(-50%);

    clip-path:polygon(50% 100%,0 0,100% 0);

    background:inherit;

}

.string{

    position:absolute;

    width:2px;

    height:70px;

    background:white;

    left:50%;

    bottom:-70px;

    transform:translateX(-50%);

}

.shine{

    position:absolute;

    width:12px;

    height:28px;

    border-radius:50%;

    background:rgba(255,255,255,.45);

    left:18px;

    top:18px;

    transform:rotate(20deg);

}

/* ==========================================
   COLORS
========================================== */

.pink{

background:linear-gradient(#ff9bcf,#ff4f9e);

}

.purple{

background:linear-gradient(#c19bff,#7c4dff);

}

.blue{

background:linear-gradient(#9ddcff,#2aa5ff);

}

.orange{

background:linear-gradient(#ffd873,#ff9b2f);

}

.red{

background:linear-gradient(#ffaaaa,#ff5252);

}

/* ==========================================
   FLOAT
========================================== */

.balloon:nth-child(2){

animation-delay:.7s;

}

.balloon:nth-child(3){

animation-delay:1.4s;

}

.balloon:nth-child(4){

animation-delay:2.1s;

}

.balloon:nth-child(5){

animation-delay:2.8s;

}

@keyframes float{

0%,100%{

transform:translateY(0);

}

50%{

transform:translateY(-16px);

}

}

/* ==========================================
   POP EFFECT
========================================== */

.balloon.pop{

animation:pop .45s forwards;

}

@keyframes pop{

0%{

opacity:1;

transform:scale(1);

}

40%{

transform:scale(1.3);

}

100%{

opacity:0;

transform:scale(0);

}

}

/* ==========================================
   PHOTO MODAL
========================================== */

.modal{

position:fixed;

left:0;

top:0;

width:100%;

height:100%;

display:none;

justify-content:center;

align-items:center;

z-index:9999;

}

.modal.show{

display:flex;

animation:fade .35s;

}

.modal-overlay{

position:absolute;

width:100%;

height:100%;

background:rgba(0,0,0,.55);

backdrop-filter:blur(10px);

}

.modal-box{

position:relative;

z-index:5;

text-align:center;

}

.closeModal{

position:absolute;

top:-12px;

right:-12px;

width:42px;

height:42px;

border:none;

border-radius:50%;

cursor:pointer;

background:white;

font-size:18px;

font-weight:bold;

box-shadow:0 10px 25px rgba(0,0,0,.25);

}

/* ==========================================
   POLAROID
========================================== */

.polaroid{

width:290px;

background:white;

padding:15px 15px 60px;

border-radius:8px;

transform:rotate(-3deg);

transition:.35s;

box-shadow:0 20px 45px rgba(0,0,0,.35);

}

.polaroid:hover{

transform:rotate(0deg) scale(1.03);

}

.polaroid img{

width:100%;

height:340px;

object-fit:cover;

border-radius:5px;

}

.polaroid-caption{

margin-top:18px;

font-family:'Parisienne',cursive;

font-size:22px;

color:#444;

}

.nextBalloon{

margin-top:25px;

width:100%;

height:55px;

border:none;

border-radius:16px;

background:white;

font-size:17px;

font-weight:600;

cursor:pointer;

color:#ff4fa0;

transition:.3s;

}

.nextBalloon:hover{

transform:translateY(-4px);

}

/* ==========================================
   LETTER PAGE
========================================== */

.letter-card{

    width:100%;
    max-width:430px;

    padding:35px;

    max-height:75vh;

    overflow-y:auto;

}

.letter-card::-webkit-scrollbar{

    display:none;

}

.letter-tag{

    display:block;

    text-align:center;

    letter-spacing:2px;

    font-size:13px;

    opacity:.8;

    margin-bottom:15px;

}

.letter-card h2{

    text-align:center;

    font-family:'Parisienne',cursive;

    font-size:42px;

    margin-bottom:25px;

}

.letter-content{

    font-size:16px;

    line-height:2;

    white-space:pre-line;

    opacity:.95;

}

/* ==========================================
   FINAL POPUP
========================================== */

.final-popup{

    position:fixed;

    inset:0;

    display:none;

    justify-content:center;

    align-items:center;

    background:rgba(0,0,0,.55);

    backdrop-filter:blur(12px);

    z-index:99999;

}

.final-popup.show{

    display:flex;

    animation:fade .4s;

}

.final-card{

    width:92%;

    max-width:400px;

    padding:35px;

    text-align:center;

}

.gift{

    font-size:70px;

    margin-bottom:20px;

    animation:bounce 1.5s infinite;

}

.final-card h2{

    font-size:34px;

    margin-bottom:8px;

}

.final-card h3{

    font-size:26px;

    margin-bottom:20px;

    color:#ffe8f5;

}

.final-card p{

    line-height:1.8;

    margin-bottom:28px;

}

#replayBtn{

    width:100%;

    height:58px;

    border:none;

    border-radius:18px;

    background:#fff;

    color:#ff4d95;

    font-size:18px;

    font-weight:600;

    cursor:pointer;

    transition:.3s;

}

#replayBtn:hover{

    transform:translateY(-4px);

    box-shadow:0 15px 30px rgba(255,255,255,.25);

}

@keyframes bounce{

0%,100%{

transform:translateY(0);

}

50%{

transform:translateY(-10px);

}

}

/* ==========================================
   STARS
========================================== */

.stars{

    position:fixed;

    inset:0;

    pointer-events:none;

    z-index:-2;

}

.stars span{

    position:absolute;

    width:4px;

    height:4px;

    border-radius:50%;

    background:#fff;

    animation:twinkle 3s infinite;

}

.stars span:nth-child(1){top:10%;left:15%;}
.stars span:nth-child(2){top:20%;left:80%;}
.stars span:nth-child(3){top:40%;left:60%;}
.stars span:nth-child(4){top:70%;left:20%;}
.stars span:nth-child(5){top:80%;left:75%;}
.stars span:nth-child(6){top:35%;left:35%;}
.stars span:nth-child(7){top:55%;left:90%;}
.stars span:nth-child(8){top:12%;left:50%;}

@keyframes twinkle{

0%,100%{

opacity:.2;

transform:scale(.8);

}

50%{

opacity:1;

transform:scale(1.8);

}

}

/* ==========================================
   CONFETTI
========================================== */

#confetti-container{

    position:fixed;

    inset:0;

    pointer-events:none;

    overflow:hidden;

    z-index:99998;

}

.confetti{

    position:absolute;

    width:10px;

    height:18px;

    border-radius:2px;

    animation:confettiFall linear forwards;

}

@keyframes confettiFall{

0%{

transform:translateY(-20px) rotate(0);

}

100%{

transform:translateY(120vh) rotate(720deg);

}

}

/* ==========================================
   FOOTER
========================================== */

footer{

    position:fixed;

    bottom:15px;

    left:50%;

    transform:translateX(-50%);

    font-size:13px;

    opacity:.8;

    letter-spacing:1px;

}

/* ==========================================
   RESPONSIVE
========================================== */

@media(max-width:480px){

.hero-card,
.balloon-card,
.letter-card{

padding:25px;

}

.hero-card h1{

font-size:36px;

}

.hero-card h2{

font-size:30px;

}

.balloon{

width:78px;

height:100px;

}

.polaroid{

width:260px;

}

.polaroid img{

height:300px;

}

.navbar{

height:66px;

}

.logo{

font-size:17px;

}

.nav-btn,
#musicButton{

width:40px;

height:40px;

}

}

/* ==========================================
   SCROLLBAR
========================================== */

::-webkit-scrollbar{

width:6px;

}

::-webkit-scrollbar-thumb{

background:rgba(255,255,255,.35);

border-radius:20px;

}

/* ==========================================
   SELECTION
========================================== */

::selection{

background:#ff4d95;

color:#fff;

}

</style>

</head>

